# Base domain all services are published under (e.g. grafana.<DOMAIN_BASE>)
DOMAIN_BASE=example.com

TZ=America/New_York

# Fine-grained PAT (contents read/write on this repo only) used by
# config-agent to push UI-made HA yaml edits back to git
HOMELAB_PUSH_TOKEN=changeme

# Home Assistant long-lived access token, used by config-agent to reload HA
# after a config sync (create under HA profile -> Security)
HA_TOKEN=changeme
